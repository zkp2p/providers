{
  "countryCode": "br",
  "actionType": "transfer_mercado_pago_br",
  "authLink": "https://www.mercadopago.com.br/home",
  "url": "https://www.mercadopago.com.br/activities/detail/{{PAYMENT_ID}}?from={{URL_PARAMS_FROM}}",
  "method": "GET",
  "body": "",
  "metadata": {
    "platform": "mercadopago",
    "urlRegex": "https://www.mercadopago.com.br/home",
    "method": "GET",
    "fallbackUrlRegex": "",
    "fallbackMethod": "",
    "preprocessRegex": "<script\\s+[^>]*id=[\"']__PRELOADED_STATE__[\"'][^>]*>([\\s\\S]*?)</script>",
    "transactionsExtraction": {
      "transactionJsonPathListSelector": "$.pageState.mpHome.result.sections.activities.content.activities_container.results",
      "transactionJsonPathSelectors": {
        "recipient": "$.title",
        "amount": "$.amount.fraction",
        "date": "$.creationDate",
        "paymentId": "$.id",
        "currency": "$.amount.currency_id"
      }
    },
    "proofMetadataSelectors": [
      {
        "type": "jsonPath",
        "value": "$.pageState.mpHome.result.sections.activities.content.activities_container.results[{{INDEX}}].title"
      },
      {
        "type": "jsonPath",
        "value": "$.pageState.mpHome.result.sections.activities.content.activities_container.results[{{INDEX}}].amount.fraction"
      },
      {
        "type": "jsonPath",
        "value": "$.pageState.mpHome.result.sections.activities.content.activities_container.results[{{INDEX}}].id"
      }
    ]
  },
  "paramNames": [
    "PAYMENT_ID",
    "URL_PARAMS_FROM"
  ],
  "paramSelectors": [
    {
      "type": "jsonPath",
      "value": "$.pageState.mpHome.result.sections.activities.content.activities_container.results[{{INDEX}}].id"
    },
    {
      "type": "regex",
      "value": "(mp-home)"
    }
  ],
  "skipRequestHeaders": [
    "Cookie",
    "Accept-Encoding"
  ],
  "secretHeaders": [
    "Cookie"
  ],
  "responseMatches": [
    {
      "type": "regex",
      "value": "\"name\":\"(?<recipientName>[^\"]+)\",\"email\":\"",
      "hash": true
    },
    {
      "type": "regex",
      "value": "\"fraction\":\"(?<amt>[0-9]+)\",\"decimal_separator\":\",\",\"cents\":\"(?<cents>[0-9]+)\""
    },
    {
      "type": "regex",
      "value": "\"currency_id\":\"(?<curr>[^\"]+)\""
    },
    {
      "type": "regex",
      "value": "\"date\":\"(?<date>[^\"]+)\""
    },
    {
      "type": "regex",
      "value": "\"operationId\":(?<paymentId>[^,]+),\"activityName\":\"(?<paymentType>[^\"]+)\",\"activityStatus\":\"(?<paymentStatus>[^\"]+)\""
    },
    {
      "type": "regex",
      "value": "\"ID de transa(?:ção|Ã§Ã£o) Pix: (?<pixId>[A-Za-z0-9]+)\""
    }
  ],
  "responseRedactions": [
    {
      "jsonPath": "",
      "xPath": "",
      "regex": "\"name\":\"([^\"]+)\",\"email\":\""
    },
    {
      "jsonPath": "",
      "xPath": "",
      "regex": "\"fraction\":\"([0-9]+)\",\"decimal_separator\":\",\",\"cents\":\"([0-9]+)\""
    },
    {
      "jsonPath": "",
      "xPath": "",
      "regex": "\"currency_id\":\"([^\"]+)\""
    },
    {
      "jsonPath": "",
      "xPath": "",
      "regex": "\"date\":\"([^\"]+)\""
    },
    {
      "jsonPath": "",
      "xPath": "",
      "regex": "\"operationId\":([^,]+),\"activityName\":\"([^\"]+)\",\"activityStatus\":\"([^\"]+)\""
    },
    {
      "jsonPath": "",
      "xPath": "",
      "regex": "\"ID de transa(?:ção|Ã§Ã£o) Pix: ([A-Za-z0-9]+)\""
    }
  ]
}
