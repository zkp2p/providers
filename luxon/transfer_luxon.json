{
  "actionType": "transfer_luxon",
  "proofEngine": "reclaim",
  "authLink": "https://web.luxon.com/dashboard",
  "url": "https://client-service.luxon.com/api/v4/transfers/{{TRANSFER_ID}}",
  "method": "GET",
  "body": "",
  "metadata": {
    "platform": "luxon",
    "urlRegex": "https://client-service\\.luxon\\.com/api/v4/transfers/[a-f0-9\\-]{36}",
    "method": "GET",
    "fallbackUrlRegex": "",
    "fallbackMethod": "",
    "preprocessRegex": "",
    "transactionsExtraction": {
      "transactionJsonPathListSelector": "",
      "transactionJsonPathSelectors": {
        "recipient": "$.receiver.label",
        "amount": "$.receiver.value.amount",
        "date": "$.createdAt",
        "paymentId": "$.transferId",
        "currency": "$.receiver.value.currency",
        "status": "$.status"
      }
    },
    "proofMetadataSelectors": [
      {
        "type": "jsonPath",
        "value": "$.receiver.value.amount"
      },
      {
        "type": "jsonPath",
        "value": "$.transferId"
      },
      {
        "type": "jsonPath",
        "value": "$.receiver.id"
      },
      {
        "type": "jsonPath",
        "value": "$.createdAt"
      },
      {
        "type": "jsonPath",
        "value": "$.status"
      }
    ],
    "userInput": {
      "promptText": "Select a transfer below to proceed with authentication",
      "transactionXpath": "//div[contains(@class,'Transfers_fullWidth')]//table//tbody"
    }
  },
  "paramNames": [
    "TRANSFER_ID"
  ],
  "paramSelectors": [
    {
      "type": "regex",
      "value": "transfers/([a-f0-9\\-]{36})",
      "source": "url"
    }
  ],
  "skipRequestHeaders": [
    "Accept-Encoding"
  ],
  "secretHeaders": [
    "X-Auth-Token"
  ],
  "responseMatches": [
    {
      "type": "regex",
      "value": "\"transferId\"\\s*:\\s*\"(?<transferId>[^\"]+)\""
    },
    {
      "type": "regex",
      "value": "\"status\"\\s*:\\s*\"(?<status>[^\"]+)\""
    },
    {
      "type": "regex",
      "value": "\"createdAt\"\\s*:\\s*\"(?<createdAt>[^\"]+)\""
    },
    {
      "type": "regex",
      "value": "\"amount\"\\s*:\\s*(?<amount>[0-9\\.]+)"
    },
    {
      "type": "regex",
      "value": "\"currency\"\\s*:\\s*\"(?<currency>[^\"]+)\""
    },
    {
      "type": "regex",
      "value": "\"email\"\\s*:\\s*\"(?<email>[^\"]+)\""
    },
    {
      "type": "regex",
      "value": "\"id\"\\s*:\\s*\"(?<receiverId>[a-f0-9\\-]{36})\""
    }
  ],
  "responseRedactions": [
    {
      "jsonPath": "$.transferId",
      "xPath": ""
    },
    {
      "jsonPath": "$.status",
      "xPath": ""
    },
    {
      "jsonPath": "$.createdAt",
      "xPath": ""
    },
    {
      "jsonPath": "$.receiver.value.amount",
      "xPath": ""
    },
    {
      "jsonPath": "$.receiver.value.currency",
      "xPath": ""
    },
    {
      "jsonPath": "$.receiver.email",
      "xPath": ""
    },
    {
      "jsonPath": "$.receiver.id",
      "xPath": ""
    }
  ]
}
